<div class="box py-3 card-columns">
{{#messages}}
    <div class="card">
        <div class="card-body">
            <p class="card-text">{{message}}</p>
            <p class="card-text">{{#str}} postedby, local_greetings, {{firstname}} {{/str}}</p>
            {{#candeleteany}}
                <p class="card-footer text-center">
                    <form action="{{config.wwwroot}}/local/greetings/index.php" method="post">
                        <input type="hidden" name="sesskey" value="{{config.sesskey}}">
                        <input type="hidden" name="action" value="del">
                        <input type="hidden" name="id" value="{{id}}">
                        
                        <button type="submit" class="btn btn-link p-0 m-0 border-0 align-baseline">
                            {{#pix}} t/delete, core {{/pix}}
                            {{#str}} delete {{/str}}
                        </button>
                    </form>
                </p>
            {{/candeleteany}}
            <p class="card-text">
                <small class="text-muted">
                    {{#userdate}} {{timecreated}}, {{#str}} strftimedaydatetime, core_langconfig {{/str}} {{/userdate}}
                </small>
            </p>
        </div>
    </div>
{{/messages}}
</div>